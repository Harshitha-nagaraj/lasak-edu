rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to all major collections
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /partners/{partnerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /popup_config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /popup_slides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Support and Meta collections
    match /contact_info/{infoId} { allow read: if true; allow write: if request.auth != null; }
    match /about_content/{contentId} { allow read: if true; allow write: if request.auth != null; }
    match /video_testimonials/{id} { allow read: if true; allow write: if request.auth != null; }
    match /youtube_videos/{id} { allow read: if true; allow write: if request.auth != null; }
    match /certificates/{id} { allow read: if true; allow write: if request.auth != null; }
    match /workshops/{id} { allow read: if true; allow write: if request.auth != null; }
    match /categories/{id} { allow read: if true; allow write: if request.auth != null; }
    match /accreditations/{id} { allow read: if true; allow write: if request.auth != null; }
    match /program_features/{id} { allow read: if true; allow write: if request.auth != null; }
    match /cert_how_it_works/{id} { allow read: if true; allow write: if request.auth != null; }
    match /cert_credentials_section/{id} { allow read: if true; allow write: if request.auth != null; }
    match /cert_faqs/{id} { allow read: if true; allow write: if request.auth != null; }
    match /cert_support_section/{id} { allow read: if true; allow write: if request.auth != null; }
    match /news/{id} { allow read: if true; allow write: if request.auth != null; }
    match /mous/{id} { allow read: if true; allow write: if request.auth != null; }
    match /seo_settings/{id} { allow read: if true; allow write: if request.auth != null; }
    match /scholarships/{id} { allow read: if true; allow write: if request.auth != null; }
    match /scholarship_rules/{id} { allow read: if true; allow write: if request.auth != null; }
    match /scholarship_settings/{id} { allow read: if true; allow write: if request.auth != null; }
    match /coupons/{id} { allow read: if true; allow write: if request.auth != null; }

    // Enquiries - Allow users to create, admins to read/write
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Enrollments (Razorpay payments) - Anyone can create, admins can read/manage
    match /enrollments/{enrollmentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Default: Deny all
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}