{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "experimentalDecorators": false,
    "paths": {
      "@/": [
        "./"
      ]
    },
    "noEmit": true,
    "types": [
      "vite/client"
    ]
  }
}